# =============================================================================
# MindfulQALB – Root .env (Frontend + Vite only)
# Copy to .env in project root. Only VITE_* are exposed to the browser.
# Server secrets → backend/.env (used by npm run dev:api and Vercel api/*)
# =============================================================================

# Supabase — use your real project URL locally for auth (not api.mindfulqalb.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_USE_DIRECT=true

# Google sign-in (Client ID only — never the secret)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# API
VITE_USE_BACKEND_API=true
VITE_BACKEND_URL=/api
