# =============================================================================
# MindfulQALB – Root .env (Frontend + Local API)
# Copy to .env and fill in values. Used by: Vite (frontend) + server.js (local API)
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) – only VITE_* are exposed to the client
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://api.mindfulqalb.com
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_USE_BACKEND_API=true
VITE_BACKEND_URL=/api

# -----------------------------------------------------------------------------
# Local API (server.js) / Vercel serverless (api/*)
# Set these so bookings persist to Supabase and payment/calendar work
# -----------------------------------------------------------------------------
# When VITE_SUPABASE_URL=api.mindfulqalb.com, the sb-proxy needs the REAL Supabase URL.
# Set SUPABASE_UPSTREAM_URL to your project (e.g. https://xxx.supabase.co).
SUPABASE_UPSTREAM_URL=https://tmegikggtccjqskuwpxi.supabase.co
SUPABASE_URL=https://tmegikggtccjqskuwpxi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Google Calendar (availability + booking confirmation + Meet links)
# See docs/GOOGLE_CALENDAR_SETUP.md for setup instructions.
# -----------------------------------------------------------------------------
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
