# =============================================================================
# MindfulQALB – Root .env (Frontend + Local API)
# Copy to .env and fill in values. Used by: Vite (frontend) + server.js (local API)
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) – only VITE_* are exposed to the client
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_USE_BACKEND_API=true
VITE_BACKEND_URL=/api

# -----------------------------------------------------------------------------
# Backend: Supabase (server.js + api/*)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# If using /sb proxy with custom domain, set SUPABASE_UPSTREAM_URL to same Supabase URL
SUPABASE_UPSTREAM_URL=https://your-project.supabase.co

# -----------------------------------------------------------------------------
# Google Calendar (availability + Meet links) – see docs/GOOGLE_CALENDAR_SETUP.md
# -----------------------------------------------------------------------------
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Razorpay (INR + international USD via PayPal)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
