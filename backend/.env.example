# =============================================================================
# MindfulQALB – Backend secrets (local API: npm run dev:api from project root)
# Copy to backend/.env — never commit this file
# =============================================================================

PORT=3001

# Supabase (same project as VITE_SUPABASE_URL in root .env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_UPSTREAM_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar (availability + Meet links)
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Cal.com
CALCOM_API_KEY=
CALCOM_USERNAME=mindfulqalb
CALCOM_EVENT_TYPE_IDS={"individual-video":"","individual-audio":"","individual-chat":""}

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

ENCRYPTION_KEY=your-32-char-secret-key-here
